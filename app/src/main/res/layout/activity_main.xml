<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".MainActivity">

    <!-- BSSID 显示 -->
    <TextView
        android:id="@+id/tvBssidLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bssid_label"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvBssidValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bssid_value"
        android:textSize="20sp"
        android:fontFamily="monospace"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBssidLabel" />

    <!-- WiFi 信息卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wifiInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBssidValue">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/wifi_info_title"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- SSID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_ssid_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSsid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- BSSID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_bssid_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvWifiBssid"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- IP 地址 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_ip_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvIp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- 信号强度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_rssi_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRssi"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 频率/信道 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_frequency_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFrequency"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 链路速度 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:text="@string/wifi_linkspeed_label"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLinkSpeed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/result_default"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 查询按钮 -->
    <Button
        android:id="@+id/btnQuery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/query_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/wifiInfoCard" />

    <!-- AP 信息显示 -->
    <TextView
        android:id="@+id/tvBssMacLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/bss_mac_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnQuery" />

    <TextView
        android:id="@+id/tvBssMac"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvBssMacLabel"
        app:layout_constraintStart_toEndOf="@id/tvBssMacLabel"
        app:layout_constraintTop_toTopOf="@id/tvBssMacLabel" />

    <TextView
        android:id="@+id/tvAcIpLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ac_ip_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBssMacLabel" />

    <TextView
        android:id="@+id/tvAcIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvAcIpLabel"
        app:layout_constraintStart_toEndOf="@id/tvAcIpLabel"
        app:layout_constraintTop_toTopOf="@id/tvAcIpLabel" />

    <TextView
        android:id="@+id/tvApIpLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ap_ip_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvAcIpLabel" />

    <TextView
        android:id="@+id/tvApIp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvApIpLabel"
        app:layout_constraintStart_toEndOf="@id/tvApIpLabel"
        app:layout_constraintTop_toTopOf="@id/tvApIpLabel" />

    <TextView
        android:id="@+id/tvApNameLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ap_name_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvApIpLabel" />

    <TextView
        android:id="@+id/tvApName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvApNameLabel"
        app:layout_constraintStart_toEndOf="@id/tvApNameLabel"
        app:layout_constraintTop_toTopOf="@id/tvApNameLabel" />

    <TextView
        android:id="@+id/tvApSnLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ap_sn_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvApNameLabel" />

    <TextView
        android:id="@+id/tvApSn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvApSnLabel"
        app:layout_constraintStart_toEndOf="@id/tvApSnLabel"
        app:layout_constraintTop_toTopOf="@id/tvApSnLabel" />

    <TextView
        android:id="@+id/tvApBuildingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/ap_building_label"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvApSnLabel" />

    <TextView
        android:id="@+id/tvApBuilding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/result_default"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintBottom_toBottomOf="@id/tvApBuildingLabel"
        app:layout_constraintStart_toEndOf="@id/tvApBuildingLabel"
        app:layout_constraintTop_toTopOf="@id/tvApBuildingLabel" />

    <!-- 查询结果 -->
    <TextView
        android:id="@+id/tvResultLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/result_label"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvApBuildingLabel" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvResultLabel">

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:lineSpacingExtra="4dp"
            android:text="@string/result_default"
            android:textSize="14sp" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
